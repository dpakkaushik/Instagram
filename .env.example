GEMINI_API_KEY=your_gemini_api_key_here

INSTAGRAM_USERNAME=your_instagram_username

# Comma-separated — one is picked per run based on the hour
# Options: mindset, growth, love, resilience, courage, success, peace, wisdom
QUOTE_CATEGORY=mindset,growth,love,resilience,courage,success,peace,wisdom

POST_INTERVAL_HOURS=1

# --- Official Instagram Graph API ---
IG_USER_ID=your_instagram_user_id
IG_ACCESS_TOKEN=your_instagram_access_token
IG_APP_SECRET=your_instagram_app_secret
IMGBB_API_KEY=your_imgbb_api_key

# --- Cloudinary (free account at cloudinary.com — used to host Reel video) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
